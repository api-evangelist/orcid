    {
      "info": {
        "name": "Get full ORCID record summary",
        "type": "http"
      },
      "http": {
        "method": "GET",
        "url": "https://pub.orcid.org/v3.0/:orcid_id/record",
        "params": [
          {
            "name": "orcid_id",
            "value": "",
            "type": "path",
            "description": "ORCID iD (e.g. 0000-0001-2345-6789)"
          }
        ]
      },
      "docs": "Get full ORCID record summary"
    },
